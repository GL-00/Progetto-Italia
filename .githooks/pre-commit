#!/bin/sh
# Hook versionato: rigenera il file autonomo dai sorgenti prima di
# ogni commit, cosi Progetto-Italia.html resta sempre allineato ad
# assets/. Attivalo dopo un clone con:
#     git config core.hooksPath .githooks
if command -v node >/dev/null 2>&1; then
  root="$(git rev-parse --show-toplevel)"
  node "$root/build.mjs" >/dev/null 2>&1 && git add "$root/Progetto-Italia.html"
fi
